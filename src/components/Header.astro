---
import { site, nav } from '../data/site';
---

<header
  class="fixed top-0 w-full z-50 bg-ink/97 backdrop-blur-xl border-b border-white/6"
  id="header"
>
  <div class="max-w-[1200px] mx-auto px-6 lg:px-10 h-[88px] flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-4 no-underline group shrink-0">
      <img
        src="/images/logo.png"
        alt={site.name}
        class="h-16 lg:h-20 w-auto"
      />
    </a>

    <!-- Nav Desktop -->
    <nav class="hidden lg:flex items-center gap-7">
      {
        nav.map((item) =>
          item.isCta ? (
            <a
              href={item.href}
              class="text-brass text-[13px] font-medium px-6 py-2.5 border border-brass/30 transition-all duration-300 hover:bg-brass hover:text-ink no-underline"
            >
              {item.label}
            </a>
          ) : (
            <a
              href={item.href}
              class="text-text-on-dark/40 text-[13px] font-medium tracking-[0.3px] transition-colors duration-300 hover:text-paper no-underline"
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>

    <!-- Mobile menu button -->
    <button
      class="lg:hidden flex flex-col gap-1.5 w-8 h-8 items-center justify-center"
      id="mobile-menu-btn"
      aria-label="Menü"
    >
      <span class="w-5 h-px bg-paper transition-all duration-300"></span>
      <span class="w-5 h-px bg-paper transition-all duration-300"></span>
      <span class="w-3.5 h-px bg-paper transition-all duration-300"></span>
    </button>
  </div>

  <!-- Mobile Nav -->
  <div
    class="lg:hidden hidden bg-ink border-t border-white/6 px-6 pb-6"
    id="mobile-menu"
  >
    {
      nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            'block py-3 text-[14px] font-medium no-underline border-b border-white/6 last:border-b-0',
            item.isCta ? 'text-brass' : 'text-text-on-dark/60 hover:text-paper',
          ]}
        >
          {item.label}
        </a>
      ))
    }
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
  // Close menu on link click
  menu?.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => menu?.classList.add('hidden'));
  });
</script>
