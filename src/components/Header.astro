---
import { site, nav } from '../data/site';
---

<header
  class="fixed top-0 w-full z-50 bg-ink/97 backdrop-blur-xl border-b border-white/6"
  id="header"
>
  <div class="max-w-[1200px] mx-auto px-10 h-[72px] flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-4 no-underline group">
      <div
        class="w-9 h-9 border-[1.5px] border-brass flex items-center justify-center relative"
      >
        <div
          class="w-3 h-3 border border-brass/40 rotate-45 transition-transform duration-300 group-hover:rotate-[135deg]"
        >
        </div>
      </div>
      <div>
        <span
          class="font-heading font-bold text-[17px] tracking-[4px] uppercase text-paper block"
        >
          {site.shortName}
        </span>
        <span class="font-mono text-[9px] text-text-on-dark/40 tracking-[2px] block mt-px">
          Kardeşler — Est. {site.established}
        </span>
      </div>
    </a>

    <!-- Nav -->
    <nav class="flex items-center gap-9">
      {
        nav.map((item) =>
          item.isCta ? (
            <a
              href={item.href}
              class="text-brass text-[13px] font-medium px-6 py-2.5 border border-brass/30 transition-all duration-300 hover:bg-brass hover:text-ink no-underline"
            >
              {item.label}
            </a>
          ) : (
            <a
              href={item.href}
              class="text-text-on-dark/40 text-[13px] font-medium tracking-[0.3px] transition-colors duration-300 hover:text-paper no-underline"
            >
              {item.label}
            </a>
          )
        )
      }
    </nav>
  </div>
</header>
