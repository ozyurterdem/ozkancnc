---
import { machineGroups } from '../data/site';
---

<section class="py-30 bg-paper" id="makinalar">
  <div class="max-w-[1200px] mx-auto px-10">
    <!-- Section Header -->
    <div class="grid grid-cols-2 gap-10 mb-18 items-end">
      <div>
        <div class="section-tag section-tag--eng">Makina Parkuru</div>
        <h2 class="font-heading text-[42px] font-extrabold text-text-primary tracking-tight leading-[1.1]">
          Tezgah<br />Envanteri
        </h2>
      </div>
      <div class="text-right">
        <a
          href="#"
          class="inline-flex items-center gap-2 text-text-on-dark text-[13px] font-medium no-underline text-text-secondary hover:text-text-primary transition-colors duration-300"
        >
          Tümünü Gör →
        </a>
      </div>
    </div>

    <!-- Machine Groups -->
    <div class="flex flex-col gap-14">
      {
        machineGroups.map((group) => (
          <div>
            {/* Group Title */}
            <div class="flex items-center gap-3 font-mono text-[11px] text-eng-mid tracking-[3px] uppercase pb-4 border-b border-black/6 mb-px">
              <span class="w-2 h-2 bg-eng-mid/30" />
              {group.title}
            </div>

            {/* Machines Row */}
            <div class="grid grid-cols-4 gap-px bg-black/6 border border-black/6 border-t-0">
              {group.machines.slice(0, 4).map((machine) => (
                <div class="bg-paper py-8 px-7 transition-all duration-400 hover:bg-paper-warm">
                  {/* Drawing placeholder */}
                  <div class="h-[100px] border border-black/6 mb-5 relative flex items-center justify-center bg-paper-warm corner-marks bp-grid-light">
                    <span class="font-mono text-[9px] text-text-muted/40 tracking-[1px]">
                      TEKNİK ÇİZİM
                    </span>
                  </div>

                  <h4 class="font-heading text-[15px] font-bold text-text-primary mb-1">
                    {machine.name}
                  </h4>
                  <span class="font-mono text-[10px] text-text-muted tracking-[1px]">
                    {machine.type}
                  </span>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
