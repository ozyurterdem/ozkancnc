---
import { site, sliderImages } from '../data/site';
---

<section class="min-h-screen bg-ink grid grid-cols-1 lg:grid-cols-2 relative overflow-hidden" id="hero">
  <!-- Subtle grid -->
  <div class="absolute inset-0 bp-grid pointer-events-none"></div>

  <!-- Left: Content -->
  <div class="flex items-center relative z-2 pt-[88px]">
    <div class="px-10 max-w-[540px] mx-auto w-full lg:pr-8">
      <!-- Label -->
      <div class="section-tag section-tag--brass mb-8">
        Talaşlı İmalat Merkezi
      </div>

      <!-- Heading -->
      <h1 class="font-heading text-4xl lg:text-[56px] font-extrabold leading-[1.05] text-paper tracking-tight mb-3">
        Hassas Üretim,<br />
        <span class="font-medium text-text-on-dark">Güvenilir</span><br />
        Mühendislik.
      </h1>

      <!-- Sub line -->
      <div class="font-mono text-xs text-text-on-dark/40 tracking-[1px] mb-8 pb-8 border-b border-white/6">
        {site.established}'ten bu yana · {site.address.district}, {site.address.city} · ISO 9001:2015
      </div>

      <!-- Description -->
      <p class="text-base text-text-on-dark/70 leading-[1.8] mb-12 max-w-[420px]">
        {site.description}
      </p>

      <!-- Actions -->
      <div class="flex flex-col sm:flex-row gap-4 items-start sm:items-center">
        <a
          href="#iletisim"
          class="inline-flex items-center gap-2.5 px-8 py-4 bg-brass text-ink text-[13px] font-semibold tracking-[0.5px] no-underline transition-all duration-400 hover:-translate-y-px hover:shadow-[0_8px_32px_rgba(176,141,78,0.15)]"
        >
          Teklif Talep Edin
        </a>
        <a
          href="#makinalar"
          class="inline-flex items-center gap-2 px-6 py-4 text-text-on-dark text-[13px] font-medium no-underline border border-white/6 transition-all duration-300 hover:border-white/12 hover:text-paper"
        >
          Makina Parkuru →
        </a>
      </div>
    </div>
  </div>

  <!-- Right: Slider images -->
  <div class="relative hidden lg:flex items-center justify-center overflow-hidden">
    <!-- Slideshow -->
    <div class="absolute inset-0" id="hero-slideshow">
      {sliderImages.map((img, i) => (
        <img
          src={img.src}
          alt={img.alt}
          class:list={[
            'absolute inset-0 w-full h-full object-cover transition-opacity duration-1000',
            i === 0 ? 'opacity-100' : 'opacity-0',
          ]}
          data-slide={i}
          loading={i === 0 ? 'eager' : 'lazy'}
        />
      ))}
    </div>

    <!-- Dark overlay gradients -->
    <div
      class="absolute inset-0 z-1 pointer-events-none"
      style="background: linear-gradient(180deg, rgba(12,17,29,0.4) 0%, transparent 30%, transparent 70%, rgba(12,17,29,0.7) 100%), linear-gradient(90deg, rgba(12,17,29,0.85) 0%, transparent 40%);"
    ></div>

    <!-- Bottom info -->
    <div class="absolute bottom-10 right-10 z-2 text-right">
      <span class="font-mono text-[10px] text-text-on-dark/30 tracking-[2px] uppercase block">
        CNC İşleme Merkezi
      </span>
      <span class="font-mono text-[11px] text-text-on-dark/50 block mt-1">
        Arifiye / Sakarya
      </span>
    </div>
  </div>
</section>

<!-- Hero slideshow script -->
<script>
  const slides = document.querySelectorAll('#hero-slideshow img[data-slide]');
  if (slides.length > 1) {
    let current = 0;
    setInterval(() => {
      slides[current].classList.remove('opacity-100');
      slides[current].classList.add('opacity-0');
      current = (current + 1) % slides.length;
      slides[current].classList.remove('opacity-0');
      slides[current].classList.add('opacity-100');
    }, 4000);
  }
</script>
