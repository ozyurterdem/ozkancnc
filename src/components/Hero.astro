---
import { site } from '../data/site';
import ToolpathSvg from './ToolpathSvg.astro';
---

<section class="min-h-screen bg-ink grid grid-cols-2 relative overflow-hidden" id="hero">
  <!-- Subtle grid -->
  <div class="absolute inset-0 bp-grid pointer-events-none"></div>

  <!-- Left: Content -->
  <div class="flex items-center relative z-2 pt-[72px]">
    <div class="pl-10 max-w-[540px] mx-auto w-full pr-8">
      <!-- Label -->
      <div class="section-tag section-tag--brass mb-8">
        Talaşlı İmalat Merkezi
      </div>

      <!-- Heading -->
      <h1 class="font-heading text-[56px] font-extrabold leading-[1.05] text-paper tracking-tight mb-3">
        Hassas Üretim,<br />
        <span class="font-medium text-text-on-dark">Güvenilir</span><br />
        Mühendislik.
      </h1>

      <!-- Sub line -->
      <div
        class="font-mono text-xs text-text-on-dark/40 tracking-[1px] mb-8 pb-8 border-b border-white/6"
      >
        {site.established}'ten bu yana · {site.address.district}, {site.address.city} · ISO 9001:2015
      </div>

      <!-- Description -->
      <p class="text-base text-text-on-dark/70 leading-[1.8] mb-12 max-w-[420px]">
        {site.description}
      </p>

      <!-- Actions -->
      <div class="flex gap-5 items-center">
        <a
          href="#iletisim"
          class="inline-flex items-center gap-2.5 px-8 py-4 bg-brass text-ink text-[13px] font-semibold tracking-[0.5px] no-underline transition-all duration-400 hover:-translate-y-px hover:shadow-[0_8px_32px_rgba(176,141,78,0.15)]"
        >
          Teklif Talep Edin
        </a>
        <a
          href="#makinalar"
          class="inline-flex items-center gap-2 px-6 py-4 text-text-on-dark text-[13px] font-medium no-underline border border-white/6 transition-all duration-300 hover:border-white/12 hover:text-paper"
        >
          Makina Parkuru →
        </a>
      </div>
    </div>
  </div>

  <!-- Right: Visual -->
  <div class="relative flex items-center justify-center overflow-hidden">
    <!-- Toolpath animation -->
    <div class="absolute inset-0 bg-gradient-to-br from-ink-2 to-ink-3 flex items-center justify-center">
      <ToolpathSvg />
    </div>

    <!-- Photo overlay gradient -->
    <div
      class="absolute inset-0 z-1"
      style="background: linear-gradient(180deg, rgba(12,17,29,0.3) 0%, transparent 30%, transparent 70%, rgba(12,17,29,0.8) 100%), linear-gradient(90deg, rgba(12,17,29,0.9) 0%, transparent 30%);"
    >
    </div>

    <!-- Photo placeholder note -->
    <div class="absolute bottom-10 right-10 z-2 text-right">
      <span class="font-mono text-[10px] text-text-on-dark/30 tracking-[2px] uppercase block">
        CNC İşleme Merkezi
      </span>
      <span class="font-mono text-[11px] text-text-on-dark/50 block mt-1">
        Fotoğraf alanı — 960×1080px
      </span>
    </div>
  </div>
</section>
