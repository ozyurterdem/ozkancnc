---
import { certifications } from '../data/site';
---

<section class="py-20 bg-ink border-t-[3px] border-brass" id="kalite">
  <div class="max-w-[1200px] mx-auto px-10">
    <div class="flex items-center justify-between">
      <!-- Left label -->
      <div class="flex items-center gap-4">
        <span class="font-mono text-[11px] text-brass tracking-[3px] uppercase">
          Kalite Belgeleri
        </span>
        <div class="w-10 h-px bg-brass/30"></div>
      </div>

      <!-- Badges -->
      <div class="flex gap-8">
        {
          certifications.map((cert) => (
            <div class="text-center py-6 px-9 border border-white/6 transition-all duration-300 hover:border-white/12">
              <div class="font-heading text-lg font-bold text-paper tracking-[1px]">
                {cert.name}
              </div>
              <div class="font-mono text-[9px] text-text-on-dark/40 tracking-[2px] uppercase mt-1">
                {cert.desc}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>
